# Taro 4 + pnpm 配置
# ==========================================================================
# 镜像: 国内 npmmirror (淘宝源), 下载 Taro 全家桶从 10MB/s 起步
# 扁平: shamefully-hoist=true 让 babel-preset-taro 等 Taro 生态硬 require
#       `@babel/preset-react` 等同级依赖时找得到
# ==========================================================================
registry=https://registry.npmmirror.com/
shamefully-hoist=true
strict-peer-dependencies=false
auto-install-peers=true

# 二进制包镜像 (esbuild / @swc / sharp / @parcel/watcher ...)
esbuild_binary_site=https://registry.npmmirror.com/-/binary/esbuild
electron_mirror=https://registry.npmmirror.com/-/binary/electron/
sass_binary_site=https://registry.npmmirror.com/-/binary/node-sass
sharp_binary_host=https://registry.npmmirror.com/-/binary/sharp
sharp_libvips_binary_host=https://registry.npmmirror.com/-/binary/sharp-libvips
puppeteer_download_host=https://registry.npmmirror.com/-/binary
