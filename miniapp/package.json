{
  "name": "longarch-miniapp",
  "version": "0.1.0",
  "private": true,
  "description": "陇上管家 · 微信小程序 (认养用户端 · Taro 4 + React 18 + TS)",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:weapp:watch": "taro build --type weapp --watch",
    "dev:weapp": "npm run build:weapp:watch",
    "build:h5": "taro build --type h5",
    "preview:h5": "node scripts/preview-h5.mjs --port 12188 --dir dist/h5",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config e2e/jest.e2e.config.js",
    "test:ci": "pnpm type-check && pnpm build:weapp && pnpm test:unit"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.24.3",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@babel/preset-typescript": "^7.24.1",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-platform-h5": "^4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.2",
    "@types/jest": "^29.5.12",
    "@types/react": "18.2.79",
    "@types/webpack-env": "^1.18.5",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-taro": "4.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "miniprogram-automator": "^0.12.1",
    "postcss": "^8.4.38",
    "react-refresh": "^0.14.2",
    "sass": "^1.77.2",
    "sass-loader": "^14.2.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "@tarojs/binding",
      "@tarojs/cli",
      "core-js",
      "core-js-pure",
      "esbuild"
    ]
  }
}
