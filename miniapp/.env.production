# miniapp · 生产环境配置
# ============================================================
#  自动被 Taro 4 加载 (pnpm build:weapp / build:h5 时启用)
#  上线前把下面两个变量替换成真实生产域名 (必须 HTTPS + 备案)
# ============================================================

TARO_APP_API_BASE=https://api.yourdomain.com/api/v1

# 摄像头实时直播 H5 播放页 (备案 HTTPS 域名)
# 留空则 miniapp 摄像头页走快照模式 (推荐 · 流量友好)
TARO_APP_CAMERA_H5_BASE=
