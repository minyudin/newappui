# Longarch2 docker compose 环境变量样例
# 复制为 .env 后按需修改:  cp .env.example .env
# ------------------------------------------------------------------

# 启动 profile: dev (微信 stub + 自动播种管理员, 适合演示) / prod (上线)
SPRING_PROFILES_ACTIVE=dev

# ---- 对外端口 ----
SERVER_PORT=8081
ADMIN_PORT=8080
DB_PORT=3306
REDIS_PORT=6379
MQTT_PORT=1883
SRS_RTMP_PORT=1935
SRS_API_PORT=1985
SRS_HTTP_PORT=8880

# ---- MySQL ----
DB_NAME=longarch
DB_USERNAME=root
DB_PASSWORD=123456

# ---- Redis ----
REDIS_PASSWORD=123456

# ---- MQTT ----
# dev: mosquitto 允许匿名连接, 任意账号密码即可
# prod 无证书方案 (推荐, 最省事): 明文 tcp:// + 账号密码 + 打开 allow-insecure
#   MQTT_BROKER_URL=tcp://mosquitto:1883
#   MQTT_AUTH_MODE=password          # (在 application-prod.yml / 环境变量中设置)
#   MQTT_USERNAME=<改成非 longarch 的账号>
#   MQTT_PASSWORD=<改成非 longarch123 的强密码>
#   MQTT_ALLOW_INSECURE=true         # 允许 prod 用明文 tcp://, 不需要任何 TLS/证书
#   ⚠️ 前提: 1883 端口只在内网/同机可达, 切勿对公网开放
MQTT_BROKER_URL=tcp://mosquitto:1883
MQTT_USERNAME=longarch
MQTT_PASSWORD=longarch123
MQTT_ALLOW_INSECURE=false

# ---- 微信小程序 (prod 必填; dev 留空走 stub 模式) ----
WX_APP_ID=
WX_APP_SECRET=
WX_MINIAPP_STUB_MODE=true

# ---- 智谱 AI (可选, 留空则 AI 问答/分析不可用, 但不影响启动) ----
ZHIPU_API_KEY=

# ---- 大屏令牌 (prod 必填; 大屏 /api/v1/screen 等接口鉴权用) ----
DASHBOARD_TOKEN=

# ---- SRS 媒体服务器 (摄像头直播) ----
# api-base 在 compose 里已固定为容器内 http://srs:1985, 无需在此配置.
# 下面三个是"回给浏览器/小程序的播放地址", 演示默认 localhost;
# 上线时改成你的域名, 并经 HTTPS 反代到 srs 的 8880/1935.
SRS_RTMP_BASE=rtmp://localhost:1935
SRS_HTTP_FLV_BASE=http://localhost:8880
SRS_HLS_BASE=http://localhost:8880
